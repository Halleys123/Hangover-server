# Server Configuration
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Database & Authentication
MONGODB_URI=mongodb://localhost:27017/hangover
JWT_SECRET=super-secret-jwt-key-change-in-production

# AI & LLM Provider Settings (OpenAI or compatible free/low-cost endpoints)
# Option A: Standard OpenAI
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
# Option B: Alternative OpenAI-Compatible Providers (e.g. Groq, OpenRouter, Ollama)
# LLM_API_KEY=your_alternative_api_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama3-8b-8192

# Cognee Memory Layer Configuration
# Optional: URL if connecting to an external Cognee Python/FastAPI service
COGNEE_API_URL=http://localhost:8000
# Optional: Hybrid database storage backends
COGNEE_GRAPH_DB_URL=neo4j://localhost:7687
COGNEE_VECTOR_DB_URL=lancedb://data/vectors
