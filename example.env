# Server Configuration
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Database & Authentication
MONGODB_URI=mongodb://localhost:27017/hangover
JWT_SECRET=super-secret-jwt-key-change-in-production

# AI & LLM Provider Settings
# Specify the AI Provider method: 'openrouter', 'openai', 'ollama', 'groq', or 'custom'
AI_PROVIDER=openrouter

# Option A: OpenRouter (Recommended for Hackathons & Multi-Model Access)
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Option B: Standard OpenAI
# OPENAI_API_KEY=sk-proj-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Option C: Groq (High Speed Inference)
# GROQ_API_KEY=gsk_your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Option D: Ollama (Local AI)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3:8b

# Option E: Custom OpenAI-Compatible Endpoint
# LLM_BASE_URL=https://api.yourprovider.com/v1
# LLM_API_KEY=your_api_key
# LLM_MODEL=your_model_name

# Cognee Memory Layer Configuration
# Optional: URL if connecting to an external Cognee Python/FastAPI service
COGNEE_API_URL=http://localhost:8000
# Optional: Hybrid database storage backends
COGNEE_GRAPH_DB_URL=neo4j://localhost:7687
COGNEE_VECTOR_DB_URL=lancedb://data/vectors
