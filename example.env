# Server Configuration
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Database & Authentication
MONGODB_URI=mongodb://localhost:27017/hangover
JWT_SECRET=super-secret-jwt-key-change-in-production

# AI & LLM Provider Settings
# Specify the AI Provider method: 'openrouter', 'nvidia', 'openai', 'ollama', 'groq', or 'custom'
AI_PROVIDER=openrouter

# Option A: OpenRouter (Recommended for Hackathons & Free/Multi-Model Access)
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
# OPENROUTER_MODEL=openrouter/free
# Optional attribution headers shown in OpenRouter analytics/leaderboards
# OPENROUTER_SITE_URL=http://localhost:5173
# OPENROUTER_APP_NAME=Hangover Hardware Copilot

# Option B: NVIDIA NIM / NVIDIA API Catalog (OpenAI-compatible hosted endpoint)
# NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Option C: Standard OpenAI
# OPENAI_API_KEY=sk-proj-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Option D: Groq (High Speed Inference)
# GROQ_API_KEY=gsk_your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Option E: Ollama (Local AI)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3:8b

# Option F: Custom OpenAI-Compatible Endpoint
# LLM_BASE_URL=https://api.yourprovider.com/v1
# LLM_API_KEY=your_api_key
# LLM_MODEL=your_model_name

# Cognee Memory Layer Configuration
# Optional: URL if connecting to an external Cognee Python/FastAPI service
COGNEE_API_URL=http://localhost:8000
# Optional: Hybrid database storage backends
COGNEE_GRAPH_DB_URL=neo4j://localhost:7687
COGNEE_VECTOR_DB_URL=lancedb://data/vectors
